	import java.util.List;
	import java.util.ArrayList;

	class Car {
		String model;

		Car(String model) {
			this.model = model;
		}
	}

	class Driver {
		String name;
		// Aggregation: Driver has cars, but cars exist independently
		private List<Car> cars;

		Driver(String name, List<Car> cars) {
			this.name = name;
			this.cars = cars;
		}

		void showCars() {
			System.out.println(name + " drives:");
			for (Car c : cars) {
